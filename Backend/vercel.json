{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "SENDER_EMAIL": "@sender_email",
    "SENDER_PASSWORD": "@sender_password",
    "FRONTEND_URL": "@frontend_url"
  }
}
