// VERIFY EMAIL OTP - Mark email as verified after OTP confirmation
// ═══════════════════════════════════════════════════════════════════════
exports.verifyEmailOTP = async (req, res) => {
  try {
    console.log('\n' + '═'.repeat(70));
    console.log('✉️  EMAIL VERIFICATION REQUEST');
    console.log('═'.repeat(70));

    const { email, otp } = req.body;

    // ─── VALIDATION: Check email and OTP provided ─────────────────────────
    if (!email || !otp) {
      console.error('❌ Missing email or OTP');
      return res.status(400).json({
        success: false,
        message: 'Email and OTP are required'
      });
    }

    console.log(`📧 Email received: ${email}`);
    console.log(`🔐 OTP received: ${otp.substring(0, 2)}****`);

    // ─── DATABASE: Find user by email ──────────────────────────────────────
    console.log(`🔍 Looking up user...`);
    const user = await User.findOne({ email: email.toLowerCase() }).select('+otpCode');

    if (!user) {
      console.error(`❌ User not found: ${email}`);
      return res.status(404).json({
        success: false,
        message: 'User not found. Please check your email or register again.'
      });
    }

    // ─── VALIDATION: Check if already verified ────────────────────────────
    if (user.isEmailVerified) {
      console.warn(`⚠️  Email already verified for: ${email}`);
      return res.status(400).json({
        success: false,
        message: 'This email is already verified. Please try logging in.'
      });
    }

    // ─── VALIDATION: Check if OTP was generated ───────────────────────────
    if (!user.otpCode || !user.otpExpires) {
      console.error(`❌ No OTP found for user: ${email}`);
      return res.status(400).json({
        success: false,
        message: 'No OTP has been generated. Please request a new registration link.'
      });
    }

    // ─── VALIDATION: Check if OTP is expired ──────────────────────────────
    const now = new Date();
    if (now > user.otpExpires) {
      console.error(`❌ OTP expired for user: ${email}`);
      // Clear expired OTP
      user.otpCode = null;
      user.otpExpires = null;
      await user.save();
      return res.status(400).json({
        success: false,
        message: 'OTP has expired. Please start registration again to receive a new OTP.'
      });
    }

    // ─── VALIDATION: Check if OTP matches ─────────────────────────────────
    if (user.otpCode !== otp) {
      console.error(`❌ Incorrect OTP for user: ${email}`);
      return res.status(400).json({
        success: false,
        message: 'Incorrect OTP. Please check and try again.'
      });
    }

    // ─── UPDATE: Mark email as verified and clear OTP ────────────────────
    console.log(`\n💾 Marking email as verified...`);
    user.isEmailVerified = true;
    user.otpCode = null;
    user.otpExpires = null;
    await user.save();

    console.log(`✓ Email verified for user: ${email}`);

    // ─── SUCCESS: Return response ──────────────────────────────────────────
    console.log(`\n✅ EMAIL VERIFICATION: SUCCESS`);
    console.log('═'.repeat(70) + '\n');

    res.status(200).json({
      success: true,
      message: 'Email verified successfully! You can now log in with your credentials.',
      isEmailVerified: true,
      email: email
    });

  } catch (error) {
    console.error('\n❌ EMAIL VERIFICATION: UNEXPECTED ERROR');
    console.error(`   Error: ${error.message}`);
    console.error('═'.repeat(70) + '\n');

    res.status(500).json({
      success: false,
      message: error.message || 'Failed to verify email. Please try again.'
    });
  }
};

