// REGISTER USER WITH EMAIL VERIFICATION (OTP)
// ═══════════════════════════════════════════════════════════════════════
exports.registerUser = async (req, res) => {
  let user = null;
  try {
    console.log('\n' + '═'.repeat(70));
    console.log('📝 NEW USER REGISTRATION REQUEST');
    console.log('═'.repeat(70));

    const {
      fullName,
      email,
      password,
      confirmPassword,
      studentId,
      faculty,
      academicYear,
      semester
    } = req.body;

    // ─── VALIDATION: Check all fields provided ────────────────────────────
    if (
      !fullName ||
      !email ||
      !password ||
      !confirmPassword ||
      !studentId ||
      !faculty ||
      !academicYear ||
      !semester
    ) {
      console.error('❌ Missing required fields');
      return res.status(400).json({
        message: 'All fields are required'
      });
    }

    // ─── VALIDATION: Passwords match ──────────────────────────────────────
    if (password !== confirmPassword) {
      console.error('❌ Passwords do not match');
      return res.status(400).json({
        message: 'Passwords do not match'
      });
    }

    // ─── VALIDATION: Password minimum length ──────────────────────────────
    if (password.length < 8) {
      console.error('❌ Password too short');
      return res.status(400).json({
        message: 'Password must be at least 8 characters long'
      });
    }

    // ─── VALIDATION: Email format and SLIIT check ──────────────────────────
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      console.error('❌ Invalid email format:', email);
      return res.status(400).json({
        message: 'Please provide a valid email address'
      });
    }

    if (!email.endsWith('@my.sliit.lk')) {
      console.error('❌ Non-SLIIT email attempted:', email);
      return res.status(400).json({
        message: 'Only SLIIT student emails (@my.sliit.lk) are allowed'
      });
    }

    console.log(`✓ Email format validated (SLIIT format)`);

    // ─── DATABASE CHECK: User already exists ───────────────────────────────
    console.log(`🔍 Checking if user already exists...`);
    const existingUser = await User.findOne({
      $or: [{ email }, { studentId }]
    });

    if (existingUser) {
      if (existingUser.email === email) {
        console.error('❌ Email already registered:', email);
        return res.status(400).json({
          message: 'This email is already registered. Please try logging in or use another email.'
        });
      }
      if (existingUser.studentId === studentId) {
        console.error('❌ Student ID already registered:', studentId);
        return res.status(400).json({
          message: 'This student ID is already registered. Please contact support if this is not you.'
        });
      }
    }

    // ─── CREATE USER: Set isEmailVerified to false ─────────────────────────
    console.log(`\n💾 Creating new user account...`);
    user = await User.create({
      fullName,
      email,
      password,
      studentId,
      faculty,
      academicYear,
      semester,
      isEmailVerified: false  // ⭐ Not verified until OTP is confirmed
    });

    console.log(`✓ User created: ${user._id}`);
    console.log(`✓ Full Name: ${user.fullName}`);
    console.log(`✓ Email: ${user.email}`);

    // ─── GENERATE: 6-digit OTP ────────────────────────────────────────────
    const otp = Math.floor(100000 + Math.random() * 900000).toString();
    const otpExpiry = new Date(Date.now() + 5 * 60 * 1000); // 5 minutes from now

    console.log(`\n📝 Generating OTP...`);
    console.log(`   OTP: ${otp}`);
    console.log(`   Expires at: ${otpExpiry.toISOString()}`);

    // ─── UPDATE: Save OTP to database ──────────────────────────────────────
    user.otpCode = otp;
    user.otpExpires = otpExpiry;
    await user.save();

    console.log(`✓ OTP saved to database`);

    // ─── EMAIL: Send verification email ────────────────────────────────────
    console.log(`\n📧 Sending verification email...`);
    const { sendVerificationEmail } = require('../services/mailService');
    
    let emailSent = false;
    try {
      await sendVerificationEmail(email, otp, fullName);
      console.log(`✅ Verification email sent successfully!`);
      console.log(`   To: ${email}`);
      emailSent = true;
    } catch (emailError) {
      console.error(`⚠️  Email sending failed (non-critical):`);
      console.error(`   Error: ${emailError.message}`);
      console.log(`   ℹ️  Account still created. User can proceed with OTP: ${otp}`);
      console.log(`   ℹ️  Check SENDER_EMAIL and SENDER_PASSWORD in .env file`);
      
      // Don't delete user - they can still use test OTP if email is misconfigured
      emailSent = false;
    }

    // ─── SUCCESS: Return response ──────────────────────────────────────────
    console.log(`\n✅ REGISTRATION: SUCCESS`);
    console.log('═'.repeat(70) + '\n');

    res.status(201).json({
      success: true,
      message: emailSent 
        ? 'Registration successful! We have sent an OTP to your email. Please verify your email to complete registration.'
        : `⚠️  Account created but email not sent. For testing, use OTP: ${otp}. Check email configuration.`,
      nextStep: 'verify-email',
      email: email,
      requiresOTP: true,
      emailSent: emailSent,
      testOTP: emailSent ? undefined : otp  // Include test OTP if email failed
    });

  } catch (error) {
    console.error('\n❌ REGISTRATION: UNEXPECTED ERROR');
    console.error(`   Error: ${error.message}`);
    console.error(`   Stack: ${error.stack}`);
    console.error('═'.repeat(70) + '\n');

    // Clean up user if something went wrong
    if (user) {
      try {
        await User.findByIdAndDelete(user._id);
        console.log('✓ Rolled back user creation');
      } catch (e) {
        console.error('Failed to rollback user creation:', e.message);
      }
    }

    res.status(500).json({
      success: false,
      message: error.message || 'Failed to register user. Please try again.'
    });
  }
};

