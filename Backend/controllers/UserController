// MARK NOTIFICATION AS READ
// ═══════════════════════════════════════════════════════════════════════
exports.markNotificationAsRead = async (req, res) => {
  try {
    const { userId, notificationId } = req.params;

    if (!userId || !notificationId || !mongoose.Types.ObjectId.isValid(userId) || !mongoose.Types.ObjectId.isValid(notificationId)) {
      return res.status(400).json({
        message: 'Invalid user ID or notification ID'
      });
    }

    const user = await User.findById(userId);
    if (!user) {
      return res.status(404).json({
        message: 'User not found'
      });
    }

    const notification = user.notifications.find(n => n._id.toString() === notificationId);
    if (!notification) {
      return res.status(404).json({
        message: 'Notification not found'
      });
    }

    notification.isRead = true;
    await user.save();

    const unreadCount = user.notifications.filter(n => !n.isRead).length;

    res.status(200).json({
      success: true,
      message: 'Notification marked as read',
      unreadCount: unreadCount
    });

  } catch (error) {
    console.error('🔴 ERROR in markNotificationAsRead:', error);
    res.status(500).json({
      message: error.message || 'Failed to mark notification as read'
    });
  }
};

