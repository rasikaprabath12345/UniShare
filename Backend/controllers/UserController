// SEND WARNING TO USER - Called by admin when approving report warning
// ═══════════════════════════════════════════════════════════════════════
exports.sendWarning = async (req, res) => {
  try {
    console.log('\n' + '═'.repeat(70));
    console.log('⚠️  SEND WARNING REQUEST');
    console.log('═'.repeat(70));

    const userId = req.params.id;
    const { message, sentByName, sentById, reportId } = req.body;
    let senderDisplayName = sentByName || 'Admin';

    // ─── VALIDATION: Check userId exists ────────────────────────────────
    if (!userId || !mongoose.Types.ObjectId.isValid(userId)) {
      console.error('❌ Invalid user ID');
      return res.status(400).json({
        message: 'Invalid user ID'
      });
    }

    // ─── VALIDATION: Check message provided ──────────────────────────────
    if (!message || !message.trim()) {
      console.error('❌ No warning message provided');
      return res.status(400).json({
        message: 'Warning message is required'
      });
    }

    console.log(`📧 Sending warning to user: ${userId}`);
    console.log(`   Message: ${message.substring(0, 50)}...`);

    // If sender is an admin, normalize display name as "Admin".
    if (sentById && mongoose.Types.ObjectId.isValid(sentById)) {
      try {
        const sender = await User.findById(sentById).select('role');
        if (sender?.role === 'admin') {
          senderDisplayName = 'Admin';
        }
      } catch (senderLookupError) {
        console.error('Failed to resolve warning sender role:', senderLookupError.message);
      }
    }

    // ─── DATABASE: Find user ─────────────────────────────────────────────
    const user = await User.findById(userId);
    if (!user) {
      console.error(`❌ User not found: ${userId}`);
      return res.status(404).json({
        message: 'User not found'
      });
    }

    // ─── ADD WARNING: Create warning object ───────────────────────────────
    const warningId = new mongoose.Types.ObjectId();
    const warning = {
      _id: warningId,
      message: message.trim(),
      sentBy: sentById,
      sentByName: senderDisplayName,
      sentAt: new Date(),
      isRead: false,
      reportId: reportId,
    };

    // Initialize warnings array if it doesn't exist
    if (!user.warnings) {
      user.warnings = [];
    }

    // Add warning to array
    user.warnings.push(warning);

    // ─── INCREMENT: Warning count ────────────────────────────────────────
    user.warningCount = (user.warningCount || 0) + 1;

    // ─── ADD NOTIFICATION: Also add to notifications array ───────────────
    if (!user.notifications) {
      user.notifications = [];
    }

    const notificationId = new mongoose.Types.ObjectId();
    user.notifications.push({
      _id: notificationId,
      type: 'warning',
      message: `You have received a warning: ${message.substring(0, 50)}...`,
      data: {
        warningId: warningId,
        sentByName: senderDisplayName,
        fullMessage: message,
      },
      isRead: false,
      createdAt: new Date(),
    });

    // ─── SAVE: Update user document ──────────────────────────────────────
    await user.save();

    console.log(`✅ Warning added successfully`);
    console.log(`   Warning ID: ${warningId}`);
    console.log(`   Total warnings: ${user.warningCount}`);
    console.log(`   Total notifications: ${user.notifications.length}`);
    console.log('═'.repeat(70) + '\n');

    res.status(200).json({
      success: true,
      message: 'Warning sent successfully',
      warningId: warningId,
      warningCount: user.warningCount,
      unreadNotifications: user.notifications.filter(n => !n.isRead).length
    });

  } catch (error) {
    console.error('🔴 ERROR in sendWarning:', error);
    res.status(500).json({
      success: false,
      message: error.message || 'Failed to send warning'
    });
  }
};

